# ============================================================================
# La Martingale — template variables d'environnement
# ============================================================================
#
# Copier ce fichier vers `.env` et remplir les valeurs réelles.
# `.env` est dans .gitignore — NE JAMAIS committer les secrets.
#
# Documentation : voir docs/DEPLOYMENT.md
# ============================================================================

# --- BDD Neon Postgres (REQUIS) -------------------------------------------
# Connection string complète depuis https://console.neon.tech → Connection Details
# Si absent, l'API bascule en mode JSON (lit les fichiers data/*.json).
DATABASE_URL=postgresql://user:password@ep-xxxx-xxxx.region.aws.neon.tech/dbname?sslmode=require

# --- Anthropic Claude (REQUIS pour RAG + chat + enrichissement) -----------
# https://console.anthropic.com/
# Provider LLM principal via src/ai/llm.ts — Sonnet (RAG) + Haiku (batch/extraction).
# Si absent → fallback automatique sur OpenAI gpt-4o-mini.
ANTHROPIC_API_KEY=sk-ant-xxxx

# --- OpenAI (REQUIS pour embeddings + hybrid search, fallback LLM) -------
# https://platform.openai.com/api-keys
# Utilisé par : src/ai/embeddings.ts (text-embedding-3-large), src/ai/search.ts.
# Sert aussi de fallback LLM si ANTHROPIC_API_KEY absent.
OPENAI_API_KEY=sk-proj-xxxx

# --- Optionnel : forcer mode BDD ------------------------------------------
# Si "true" + DATABASE_URL présent → force le chemin BDD sur les endpoints
# qui laissent le choix (auto-detect via DATABASE_URL sinon).
USE_DB=true

# --- Optionnel : port local -----------------------------------------------
# Par défaut 3001
PORT=3001

# --- Optionnel : cache Vercel KV (prévu, non actif) ------------------------
# Réservé pour la future mise en cache de /api/search/hybrid et /api/chat
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Auth Phase E (hub créateur) ------------------------------------------
# Resend (https://resend.com) pour l'envoi du magic-link passwordless.
# En l'absence de RESEND_API_KEY → mode noop : le lien est loggé en console.
# RESEND_API_KEY=re_xxxx

# Adresse "from" du magic-link. Par défaut onboarding@resend.dev (fallback Resend
# sans DNS). Pour une adresse perso, vérifier le domaine dans Resend (SPF + DKIM).
# AUTH_FROM_EMAIL=onboarding@resend.dev

# URL de base du hub, embarquée dans les magic-links (fallback = autodetect via
# headers HTTP, mais à définir explicitement en prod pour garantir HTTPS).
# AUTH_BASE_URL=https://ms-hub.vercel.app

# Secret HMAC-SHA256 pour signer les cookies de session. EN PROD : ≥ 32 chars
# random (openssl rand -hex 32). En dev : fallback dérivé de DATABASE_URL.
# SESSION_SECRET=

# TTL session cookie en jours (défaut 30).
# SESSION_TTL_DAYS=30
