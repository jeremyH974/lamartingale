{
  "name": "lamartingale",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "npx tsx engine/api.ts",
    "cli": "npx tsx cli/index.ts",
    "scrape": "npx tsx src/scraper.ts",
    "scrape:all": "npx tsx src/scraper.ts 1 30",
    "scrape:media": "npx tsx src/scrape-media.ts",
    "enrich": "npx tsx src/enrichment.ts enrich 10",
    "enrich:quiz": "npx tsx src/enrichment.ts quiz",
    "enrich:local": "npx tsx src/enrich-local.ts",
    "migrate": "npx tsx engine/db/migrate-json.ts",
    "test:regression": "npx tsx engine/db/test-regression.ts",
    "embeddings": "npx tsx engine/ai/embeddings.ts",
    "embeddings:force": "npx tsx engine/ai/embeddings.ts --force",
    "embeddings:new": "npx tsx engine/ai/embeddings.ts",
    "similarity": "npx tsx engine/ai/similarity.ts",
    "refresh": "npx tsx engine/scraping/scrape-rss.ts && npx tsx engine/scraping/scrape-deep.ts && npx tsx engine/ai/embeddings.ts && npx tsx engine/ai/similarity.ts",
    "scrape:deep": "npx tsx engine/scraping/scrape-deep.ts",
    "scrape:deep:force": "npx tsx engine/scraping/scrape-deep.ts --force",
    "scrape:rss": "npx tsx engine/scraping/scrape-rss.ts",
    "audit:deep": "npx tsx engine/db/audit-deep-scraping.ts",
    "dashboard": "npx tsx engine/ai/dashboard.ts",
    "cache:clear": "curl -X POST http://localhost:3001/api/cache/clear",
    "deploy:lm": "vercel --yes --prod --scope jeremyh974s-projects --local-config vercel-configs/vercel-lamartingale.json",
    "deploy:gdiy": "vercel --yes --prod --scope jeremyh974s-projects --local-config vercel-configs/vercel-gdiy.json",
    "deploy:hub": "vercel --yes --prod --scope jeremyh974s-projects --local-config vercel-configs/vercel-hub.json",
    "deploy": "npm run deploy:lm",
    "build": "tsc",
    "start": "node dist/api.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/openai": "^3.0.53",
    "@anthropic-ai/sdk": "^0.89.0",
    "@neondatabase/serverless": "^1.0.2",
    "@types/node": "^25.6.0",
    "@vercel/kv": "^3.0.0",
    "ai": "^6.0.161",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.7.1",
    "openai": "^6.34.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@vercel/node": "^5.7.5",
    "docx": "^9.6.1",
    "drizzle-kit": "^0.31.10",
    "marked": "^18.0.2",
    "vitest": "^4.1.4"
  }
}
